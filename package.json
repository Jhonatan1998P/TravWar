{
  "name": "project-genesis",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173 || node ./node_modules/vite/bin/vite.js --host 0.0.0.0 --port 5173",
    "start": "vite --host 0.0.0.0 --port 5173 || node ./node_modules/vite/bin/vite.js --host 0.0.0.0 --port 5173",
    "build": "vite build || node ./node_modules/vite/bin/vite.js build",
    "preview": "vite preview || node ./node_modules/vite/bin/vite.js preview",
    "perf:budget": "node scripts/perf/perf-budget.mjs",
    "build:check": "npm run build && npm run perf:budget"
  },
  "dependencies": {
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.21"
  }
}
