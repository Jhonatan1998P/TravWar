modules = ["nodejs-20", "python-3.11"]
run = "npm run dev"
[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[[ports]]
localPort = 5173
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"
